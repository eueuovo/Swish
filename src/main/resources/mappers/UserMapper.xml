<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="dev.dhkim.swish.mappers.UserMapper">
    <insert id="register" parameterType="dev.dhkim.swish.entities.user.UserEntity">
        INSERT INTO `swish`.`user` (
            `email`,
            `login_id`,
            `password`,
            `nickname`,
            `contact`,
            `created_at`
        )
        VALUES (
                   #{email},
                   #{loginId},
                   #{password},
                   #{nickname},
                   #{contact},
                   NOW()
               )
    </insert>

    <select id="login" resultType="dev.dhkim.swish.entities.user.UserEntity">
        SELECT * FROM `swish`.`user`
        WHERE login_id = #{loginId}
        AND password = #{password}
    </select>

    <select id="findByLoginId" resultType="dev.dhkim.swish.entities.user.UserEntity">
        SELECT * FROM `swish`.`user`
        WHERE login_id = #{loginId}
    </select>

    <select id="findByNickname" resultType="dev.dhkim.swish.entities.user.UserEntity">
        SELECT * FROM `swish`.`user` WHERE `nickname` = #{nickname}
    </select>

    <update id="updateDorm">
        UPDATE `swish`.`user`
        SET `dorm_id` = #{dormId}
        WHERE `id` = #{userId}
    </update>

    <select id="findAllWands" resultType="dev.dhkim.swish.entities.user.WandEntity">
        SELECT `id`, `probability` FROM `swish`.`wand`
    </select>

    <update id="updateWand">
        UPDATE `swish`.`user`
        SET `wand_id` = #{wandId}
        WHERE `id` = #{userId}
    </update>

    <select id="findWandById" resultType="dev.dhkim.swish.entities.user.WandEntity">
        SELECT *
        FROM `swish`.`wand`
        WHERE `id` = #{wandId}
    </select>

    <select id="findEnhanceWand" resultType="dev.dhkim.swish.entities.user.EnhanceWandEntity">
        SELECT * FROM `swish`.`enhance_wand`
        WHERE `wand_id` = #{wandId}
          AND `rank` = #{rank}
    </select>

    <update id="updateLastDailyRewardAt">
        UPDATE `swish`.`user`
        SET `last_daily_reward_at` = #{lastDailyRewardAt}
        WHERE `id` = #{id}
    </update>

    <insert id="addItem">
        INSERT INTO `swish`.`item_user` (`user_id`, `item_id`, `count`)
        VALUES (#{userId}, #{itemId}, #{itemCount})
        ON DUPLICATE KEY UPDATE `count` = `count` + #{itemCount}
    </insert>

    <!-- 기숙사 랭킹 조회 (user_score 합산 기준) -->
    <select id="findDormRank" resultType="int">
        SELECT `rank` FROM (
                               SELECT `u`.`dorm_id`,
                                      RANK() OVER (ORDER BY SUM(`us`.`score`) DESC) AS `rank`
                               FROM `swish`.`user` `u`
                                        JOIN `swish`.`user_score` `us` ON `u`.`id` = `us`.`user_id`
                               GROUP BY `u`.`dorm_id`
                           ) AS `ranked`
        WHERE `dorm_id` = #{dormId}
    </select>

    <!-- 갈레온 지급 -->
    <update id="addGalleon">
        UPDATE `swish`.`user`
        SET `galleon` = `galleon` + #{galleon}
        WHERE `id` = #{userId}
    </update>

    <!-- 코인 지급 -->
    <update id="addCoin">
        UPDATE `swish`.`user`
        SET `coin` = `coin` + #{coin}
        WHERE `id` = #{userId}
    </update>

    <update id="updateWandRank">
        UPDATE `swish`.`user`
        SET `wand_rank` = #{rank}
        WHERE `id` = #{userId}
    </update>
</mapper>