<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="dev.dhkim.swish.mappers.DailyRewardMapper">
    <select id="findCommonReward" resultType="dev.dhkim.swish.entities.reward.DailyRewardEntity">
        SELECT *
        FROM `swish`.`daily_reward`
        WHERE `dorm_rank` IS NULL
    </select>

    <select id="findByDormRank" resultType="dev.dhkim.swish.entities.reward.DailyRewardEntity">
        SELECT *
        FROM `swish`.`daily_reward`
        WHERE `dorm_rank` = #{dormRank}
    </select>

    <select id="findItemsByRewardId" resultType="dev.dhkim.swish.entities.reward.DailyRewardItemEntity">
        SELECT *
        FROM `swish`.`daily_reward_item`
        WHERE `daily_reward_id` = #{dailyRewardId}
    </select>

    <update id="addGalleon">
        UPDATE `swish`.`user`
        SET `galleon` = `galleon` + #{galleon}
        WHERE `id` = #{userId}
    </update>

    <update id="updateLastDailyRewardAt">
        UPDATE `swish`.`user`
        SET `last_daily_reward_at` = #{lastDailyRewardAt}
        WHERE `id` = #{id}
    </update>

    <insert id="addItem">
        INSERT INTO `swish`.`item_user` (`user_id`, `item_id`, `count`)
        VALUES (#{userId}, #{itemId}, #{itemCount})
        ON DUPLICATE KEY UPDATE `count` = `count` + #{itemCount}
    </insert>
</mapper>